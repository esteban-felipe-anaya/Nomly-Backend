# Copy to ../.env (backend/.env) and adjust. Loaded by config/settings/base.py.

# Django
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=true
ALLOWED_HOSTS=*

# Database — the PostgreSQL target. Create the DB/role first (see README):
#   createdb nomly && createuser nomly --pwprompt
DATABASE_URL=postgres://nomly:nomly@localhost:5432/nomly
# Zero-install fallback (used automatically if DATABASE_URL is unset):
# DATABASE_URL=sqlite:///db.sqlite3

# CORS (prod). In dev all origins are allowed automatically.
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080

# Optional: override the seed-data file used by `manage.py import_mock`.
# Defaults to server/apps/seed/seed_data.json.
# SEED_DATA_PATH=apps/seed/seed_data.json
